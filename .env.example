# === El Resort — Backend (Express/Mongo) ===
# Copia este archivo a `.env` y completa los valores. NUNCA subas tu `.env` real.

# --- Servidor ---
PORT=4000
NODE_ENV=development
# URL del frontend (para CORS y enlaces en correos).
FRONTEND_URL=http://localhost:5173
# Zona horaria por defecto para fechas de estancia.
APP_TIMEZONE=America/Lima
# URL pública que se muestra en Swagger (/api/docs).
SWAGGER_SERVER_URL=http://localhost:4000

# --- Base de datos ---
# Cadena de conexión de MongoDB (Atlas u otra). Requerida para conectar la BD.
DATABASE_URL=

# --- Autenticación ---
# Secreto para firmar los JWT de usuarios.
JWT_SECRET=
# Secreto y TTL para los tokens de pago (Izipay form token).
PAYMENT_TOKEN_SECRET=
PAYMENT_TOKEN_TTL_SECONDS=600

# --- Cloudbeds (motor de reservas) ---
CLOUDBEDS_BASE_URL=
CLOUDBEDS_API_KEY=
CLOUDBEDS_AUTH_MODE=
CLOUDBEDS_TIMEOUT_MS=15000

# --- Izipay (pagos) ---
IZIPAY_USERNAME_RESORT=
IZIPAY_PASSWORD_RESORT=
IZIPAY_PUBLIC_KEY_RESORT=
IZIPAY_HMAC_SHA256_RESORT=
IZIPAY_CREATE_PAYMENT_PATH_RESORT=
IZIPAY_TIMEOUT_MS=15000

# --- Google Cloud Storage (medios) ---
GCS_BUCKET_RESORT=
# JSON de credenciales de la service account (o ruta, según tu despliegue).
GOOGLE_CLOUD_STORAGE_CREDENTIALS=
# Worker de Cloudflare que sirve/optimiza vídeos.
CLOUDFLARE_WORKER_URL=

# --- Supabase (almacenamiento legacy / migración) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=
SUPABASE_MAX_IMAGE_BYTES=
SUPABASE_MAX_IMAGE_SIDE_PX=

# --- Traducción ---
# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=
GEMINI_TEMPERATURE=
# Google Translate (no oficial)
GOOGLE_TRANSLATE_HOST=
GOOGLE_TRANSLATE_TIMEOUT_MS=
# LibreTranslate
LIBRETRANSLATE_BASE_URL=
LIBRETRANSLATE_API_KEY=
LIBRETRANSLATE_TIMEOUT_MS=
LIBRETRANSLATE_DELAY_MS=

# --- Subida de archivos ---
MAX_UPLOAD_FILE_SIZE_MB=10
MAX_UPLOAD_FILE_SIZE_BYTES=
